{
  "dashboard": {
    "id": null,
    "uid": "mycel-traffic",
    "title": "Mycel Mesh - Traffic Monitor",
    "tags": ["mycel", "traffic", "network"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 0,
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "type": "stat",
        "title": "Total Received",
        "targets": [
          {
            "expr": "sum(mycel_traffic_received_bytes_total)",
            "legendFormat": "RX Total"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "none",
          "justifyMode": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "unit": "bytes",
            "decimals": 2
          }
        }
      },
      {
        "id": 2,
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "type": "stat",
        "title": "Total Sent",
        "targets": [
          {
            "expr": "sum(mycel_traffic_sent_bytes_total)",
            "legendFormat": "TX Total"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "none",
          "justifyMode": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "unit": "bytes",
            "decimals": 2
          }
        }
      },
      {
        "id": 3,
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "type": "stat",
        "title": "RX Rate",
        "targets": [
          {
            "expr": "sum(mycel_traffic_received_rate_bytes)",
            "legendFormat": "RX/sec"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "unit": "Bps"
          }
        }
      },
      {
        "id": 4,
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "type": "stat",
        "title": "TX Rate",
        "targets": [
          {
            "expr": "sum(mycel_traffic_sent_rate_bytes)",
            "legendFormat": "TX/sec"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "unit": "Bps"
          }
        }
      },
      {
        "id": 5,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "type": "timeseries",
        "title": "Traffic Rate Over Time",
        "targets": [
          {
            "expr": "rate(mycel_traffic_received_bytes_total[1m])",
            "legendFormat": "RX Rate"
          },
          {
            "expr": "rate(mycel_traffic_sent_bytes_total[1m])",
            "legendFormat": "TX Rate"
          }
        ],
        "options": {
          "legend": {"displayMode": "table", "placement": "right", "showLegend": true},
          "tooltip": {"mode": "multi", "sort": "desc"}
        },
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "Bps"
          }
        }
      },
      {
        "id": 6,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "type": "timeseries",
        "title": "Total Traffic",
        "targets": [
          {
            "expr": "mycel_traffic_received_bytes_total",
            "legendFormat": "RX Total"
          },
          {
            "expr": "mycel_traffic_sent_bytes_total",
            "legendFormat": "TX Total"
          }
        ],
        "options": {
          "legend": {"displayMode": "table", "placement": "right", "showLegend": true},
          "tooltip": {"mode": "multi", "sort": "none"}
        },
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "bytes"
          }
        }
      },
      {
        "id": 7,
        "gridPos": {"h": 6, "w": 24, "x": 0, "y": 12},
        "type": "timeseries",
        "title": "WireGuard Traffic",
        "targets": [
          {
            "expr": "rate(mycel_agent_wireguard_transmit_bytes_total[1m])",
            "legendFormat": "WG TX - {{instance}}"
          },
          {
            "expr": "rate(mycel_agent_wireguard_receive_bytes_total[1m])",
            "legendFormat": "WG RX - {{instance}}"
          }
        ],
        "options": {
          "legend": {"displayMode": "table", "placement": "right", "showLegend": true},
          "tooltip": {"mode": "multi", "sort": "desc"}
        },
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "Bps"
          }
        }
      }
    ],
    "time": {"from": "now-1h", "to": "now"},
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
    }
  },
  "overwrite": true
}
